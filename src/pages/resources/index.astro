---
import { getCollection } from "astro:content";
import PageLayout from "../../layouts/PageLayout.astro";
import PageHero from "../../components/PageHero.astro";
import Icon from "../../components/Icon.astro";
import Badge from "../../components/ui/Badge.astro";
import CTA from "../../components/sections/CTA.astro";

const guides = (await getCollection("guides")).sort(
  (a, b) => a.data.order - b.data.order,
);
---
<PageLayout
  title="Resources — EffortlessAuthor"
  description="Practical guides on Markdown-to-KDP EPUB workflows, structuring nonfiction books, EPUB navigation, and keeping a manuscript in Git."
>
  <PageHero
    eyebrow="Resources"
    eyebrowIcon="book-open"
    title="Guides for file-first authors."
    lead="Practical, production-minded writing on KDP formatting, EPUB internals, and treating a book like a project you can version."
  />

  <section class="relative z-10 py-16 lg:py-20">
    <div class="mx-auto max-w-5xl px-6 lg:px-8">
      <div class="grid gap-5 sm:grid-cols-2">
        {guides.map((g) => (
          <a
            href={`/resources/${g.id}`}
            class="group flex h-full flex-col rounded-lg border border-border/60 bg-card/80 p-6 shadow-soft backdrop-blur-sm transition-all duration-300 hover:-translate-y-1 hover:border-primary/30 hover:shadow-soft-lg"
          >
            <div class="mb-4 flex items-center justify-between gap-3">
              <Badge variant="primary">{g.data.category}</Badge>
              <span class="inline-flex items-center gap-1.5 text-xs text-muted-foreground"><Icon name="clock" class="h-3.5 w-3.5" />{g.data.readingTime}</span>
            </div>
            <h2 class="font-serif text-xl font-semibold leading-snug">{g.data.title}</h2>
            <p class="mt-2 flex-1 text-sm leading-relaxed text-muted-foreground">{g.data.description}</p>
            <span class="mt-4 inline-flex items-center gap-1.5 text-sm font-medium text-primary">Read guide<Icon name="arrow-right" class="h-4 w-4 transition-transform group-hover:translate-x-0.5" /></span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <CTA />
</PageLayout>
