---
import { getCollection, render } from "astro:content";
import PageLayout from "../layouts/PageLayout.astro";
import PageHero from "../components/PageHero.astro";
import Icon from "../components/Icon.astro";
import Button from "../components/ui/Button.astro";
import Badge from "../components/ui/Badge.astro";

const updates = (await getCollection("updates")).sort(
  (a, b) => +new Date(b.data.date) - +new Date(a.data.date),
);
const rendered = await Promise.all(
  updates.map(async (u) => ({ entry: u, Content: (await render(u)).Content })),
);
const fmt = (d: string) =>
  new Date(d + "T00:00:00").toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric" });
---
<PageLayout
  title="Updates — EffortlessAuthor"
  description="Build-in-public updates from EffortlessAuthor, the file-first KDP authoring studio."
>
  <PageHero
    eyebrow="Changelog"
    eyebrowIcon="rss"
    title="Building in the open."
    lead="Honest, frequent notes on what's shipping as EffortlessAuthor takes shape."
  >
    <div class="mt-8 flex justify-center">
      <Button href="/rss.xml" variant="outline" size="default"><Icon name="rss" class="h-4 w-4" />Subscribe via RSS</Button>
    </div>
  </PageHero>

  <section class="relative z-10 py-16 lg:py-20">
    <div class="mx-auto max-w-3xl px-6 lg:px-8">
      <ol class="relative flex flex-col gap-10 border-l border-border/60 pl-8">
        {rendered.map(({ entry, Content }) => (
          <li id={entry.id} class="relative scroll-mt-24">
            <span class="absolute -left-[calc(2rem+1px)] top-1.5 flex h-4 w-4 -translate-x-1/2 items-center justify-center rounded-full border-2 border-background bg-primary"></span>
            <div class="flex flex-wrap items-center gap-3">
              <Badge variant="primary">{entry.data.tag}</Badge>
              <time class="text-sm text-muted-foreground" datetime={entry.data.date}>{fmt(entry.data.date)}</time>
            </div>
            <h2 class="mt-3 font-serif text-2xl font-semibold tracking-tight">{entry.data.title}</h2>
            <div class="prose mt-3 max-w-none"><Content /></div>
          </li>
        ))}
      </ol>
    </div>
  </section>
</PageLayout>
