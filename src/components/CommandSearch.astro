---
/**
 * shadcn-style command palette for docs search, powered by the Pagefind JS API.
 * Render this once per page; open it from any element with `data-cmdk-open`,
 * or with Cmd/Ctrl+K (or "/"). Pagefind is loaded lazily from /pagefind on first
 * open (available in `build`/`preview`, not `astro dev`).
 */
import Icon from "./Icon.astro";
---
<div id="cmdk" class="fixed inset-0 z-[80] hidden" role="dialog" aria-modal="true" aria-label="Search the documentation">
  <div data-cmdk-overlay class="absolute inset-0 bg-black/50 backdrop-blur-sm"></div>
  <div class="absolute left-1/2 top-[12vh] w-[92vw] max-w-xl -translate-x-1/2">
    <div class="animate-scale-in overflow-hidden rounded-xl border border-border bg-popover text-popover-foreground shadow-soft-lg">
      <!-- input -->
      <div class="flex items-center gap-2.5 border-b border-border px-4">
        <Icon name="search" class="h-4 w-4 shrink-0 text-muted-foreground" />
        <input
          id="cmdk-input"
          type="text"
          autocomplete="off"
          spellcheck="false"
          placeholder="Search the docs…"
          class="h-12 w-full bg-transparent text-sm outline-none focus:shadow-none focus-visible:shadow-none placeholder:text-muted-foreground"
          aria-controls="cmdk-results"
        />
        <kbd class="hidden rounded border border-border bg-muted px-1.5 py-0.5 font-sans text-[10px] font-medium text-muted-foreground sm:inline-block">Esc</kbd>
      </div>
      <!-- results -->
      <div id="cmdk-results" class="max-h-[min(60vh,24rem)] overflow-y-auto p-2" role="listbox">
        <p data-cmdk-state="idle" class="px-3 py-8 text-center text-sm text-muted-foreground">Type to search the documentation.</p>
        <p data-cmdk-state="empty" class="hidden px-3 py-8 text-center text-sm text-muted-foreground">No results found.</p>
        <p data-cmdk-state="unavailable" class="hidden px-3 py-8 text-center text-sm text-muted-foreground">Search is available in the built site (run a production build).</p>
        <div data-cmdk-list class="flex flex-col gap-1"></div>
      </div>
      <!-- footer -->
      <div class="flex items-center gap-4 border-t border-border px-4 py-2.5 text-[11px] text-muted-foreground">
        <span class="flex items-center gap-1"><kbd class="rounded border border-border bg-muted px-1 py-0.5 font-sans">↑</kbd><kbd class="rounded border border-border bg-muted px-1 py-0.5 font-sans">↓</kbd> navigate</span>
        <span class="flex items-center gap-1"><kbd class="rounded border border-border bg-muted px-1 py-0.5 font-sans">↵</kbd> open</span>
        <span class="ml-auto flex items-center gap-1"><kbd class="rounded border border-border bg-muted px-1 py-0.5 font-sans">esc</kbd> close</span>
      </div>
    </div>
  </div>
</div>

<script is:inline>
  (() => {
    const root = document.getElementById("cmdk");
    if (!root) return;
    const input = document.getElementById("cmdk-input");
    const list = root.querySelector("[data-cmdk-list]");
    const states = {
      idle: root.querySelector('[data-cmdk-state="idle"]'),
      empty: root.querySelector('[data-cmdk-state="empty"]'),
      unavailable: root.querySelector('[data-cmdk-state="unavailable"]'),
    };
    let pagefind = null;
    let loadFailed = false;
    let selected = -1;
    let items = [];
    let token = 0;

    const showState = (key) => {
      for (const [k, el] of Object.entries(states)) el?.classList.toggle("hidden", k !== key);
    };

    async function ensurePagefind() {
      if (pagefind || loadFailed) return;
      try {
        pagefind = await import("/pagefind/pagefind.js");
        await pagefind.init?.();
      } catch (_) {
        loadFailed = true;
      }
    }

    const open = async () => {
      root.classList.remove("hidden");
      document.documentElement.style.overflow = "hidden";
      input.value = "";
      list.innerHTML = "";
      selected = -1;
      showState("idle");
      input.focus();
      await ensurePagefind();
      if (loadFailed) showState("unavailable");
    };
    const close = () => {
      root.classList.add("hidden");
      document.documentElement.style.overflow = "";
    };
    const isOpen = () => !root.classList.contains("hidden");

    const setSelected = (i) => {
      if (!items.length) return;
      selected = (i + items.length) % items.length;
      items.forEach((el, idx) => {
        const on = idx === selected;
        el.setAttribute("aria-selected", on ? "true" : "false");
        el.classList.toggle("bg-accent", on);
        el.classList.toggle("text-accent-foreground", on);
        if (on) el.scrollIntoView({ block: "nearest" });
      });
    };

    function render(results) {
      list.innerHTML = "";
      items = results.map((r) => {
        const a = document.createElement("a");
        a.href = r.url;
        a.setAttribute("role", "option");
        a.className = "flex flex-col gap-0.5 rounded-md px-3 py-2.5 no-underline transition-colors hover:bg-accent hover:text-accent-foreground";
        const title = document.createElement("span");
        title.className = "font-serif text-sm font-semibold";
        title.textContent = r.meta?.title || r.url;
        const excerpt = document.createElement("span");
        excerpt.className = "line-clamp-2 text-xs text-muted-foreground [&_mark]:bg-primary/20 [&_mark]:text-foreground";
        excerpt.innerHTML = r.excerpt || "";
        a.append(title, excerpt);
        a.addEventListener("mouseenter", () => setSelected(items.indexOf(a)));
        list.appendChild(a);
        return a;
      });
      selected = -1;
      if (results.length) setSelected(0);
    }

    let timer;
    input?.addEventListener("input", () => {
      clearTimeout(timer);
      const q = input.value.trim();
      if (!q) { list.innerHTML = ""; items = []; showState(loadFailed ? "unavailable" : "idle"); return; }
      timer = setTimeout(async () => {
        await ensurePagefind();
        if (loadFailed || !pagefind) { showState("unavailable"); return; }
        const my = ++token;
        const search = await pagefind.search(q);
        if (my !== token) return;
        const data = await Promise.all(search.results.slice(0, 8).map((r) => r.data()));
        if (my !== token) return;
        if (!data.length) { list.innerHTML = ""; items = []; showState("empty"); return; }
        showState(""); // hide all state messages
        render(data);
      }, 140);
    });

    root.addEventListener("click", (e) => {
      if (e.target.closest("[data-cmdk-overlay]")) close();
    });

    input?.addEventListener("keydown", (e) => {
      if (e.key === "ArrowDown") { e.preventDefault(); setSelected(selected + 1); }
      else if (e.key === "ArrowUp") { e.preventDefault(); setSelected(selected - 1); }
      else if (e.key === "Enter" && items[selected]) { e.preventDefault(); window.location.href = items[selected].href; }
    });

    document.addEventListener("keydown", (e) => {
      if ((e.key === "k" && (e.metaKey || e.ctrlKey))) { e.preventDefault(); isOpen() ? close() : open(); }
      else if (e.key === "Escape" && isOpen()) { e.preventDefault(); close(); }
      else if (e.key === "/" && !isOpen() && !/^(INPUT|TEXTAREA)$/.test(document.activeElement?.tagName)) { e.preventDefault(); open(); }
    });

    document.querySelectorAll("[data-cmdk-open]").forEach((btn) => btn.addEventListener("click", open));
  })();
</script>
