---
import Icon from "./Icon.astro";
import Badge from "./ui/Badge.astro";
interface Props { eyebrow?: string; eyebrowIcon?: string; title: string; center?: boolean; class?: string; }
const { eyebrow, eyebrowIcon = "sparkles", title, center = false, class: className } = Astro.props;
---
<div class={`${center ? "mx-auto text-center" : ""} max-w-2xl ${className ?? ""}`}>
  {eyebrow && (
    <Badge variant="primary" class="mb-4"><Icon name={eyebrowIcon} class="h-3.5 w-3.5" />{eyebrow}</Badge>
  )}
  <h2 class="font-serif text-3xl font-bold tracking-tight sm:text-4xl">{title}</h2>
  <div class={`mt-4 text-lg text-muted-foreground ${center ? "mx-auto" : ""}`}>
    <slot />
  </div>
</div>
