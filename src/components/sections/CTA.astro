---
import Icon from "../Icon.astro";
import Button from "../ui/Button.astro";
import Input from "../ui/Input.astro";
import Badge from "../ui/Badge.astro";

const perks = ["Early access to the studio", "Launch updates", "A say in the roadmap"];
---
<section id="early-access" class="relative z-10 py-20 lg:py-28">
  <div class="mx-auto max-w-4xl px-6 lg:px-8">
    <div class="relative overflow-hidden rounded-3xl border border-border/60 bg-card/70 p-8 shadow-soft-lg backdrop-blur-sm sm:p-12">
      <!-- warm gradient ambience -->
      <div class="pointer-events-none absolute inset-0 -z-10 bg-gradient-to-br from-primary/10 via-orange-500/5 to-amber-500/10" aria-hidden="true"></div>

      <div class="grid items-center gap-10 lg:grid-cols-[1.1fr_1fr]">
        <div>
          <Badge variant="outline" class="mb-5"><span class="h-2 w-2 rounded-full bg-emerald-500"></span>Early access</Badge>
          <h2 class="font-serif text-3xl font-bold tracking-tight sm:text-4xl">
            Join the list for a file-first authoring studio.
          </h2>
          <p class="mt-4 text-lg text-muted-foreground">
            We're building EffortlessAuthor in the open. Get launch updates and early access — no
            pricing or commitment yet.
          </p>
          <ul class="mt-6 flex flex-col gap-2.5">
            {perks.map((p) => (
              <li class="flex items-center gap-2.5 text-[15px]">
                <span class="flex h-5 w-5 flex-shrink-0 items-center justify-center rounded-full bg-primary/12 text-primary"><Icon name="check" class="h-3 w-3" /></span>
                <span class="text-muted-foreground">{p}</span>
              </li>
            ))}
          </ul>
        </div>

        <form class="flex flex-col gap-3 rounded-xl border border-border/50 bg-background/60 p-6 shadow-inner-soft" onsubmit="return false">
          <label class="text-sm font-medium" for="ea-name">Name</label>
          <Input id="ea-name" name="name" placeholder="Your name" class="h-11 border-border/50 bg-background/50 focus:border-primary/50" />
          <label class="mt-1 text-sm font-medium" for="ea-email">Email</label>
          <Input id="ea-email" type="email" name="email" placeholder="you@example.com" class="h-11 border-border/50 bg-background/50 focus:border-primary/50" />
          <Button type="submit" variant="gradient" size="lg" class="mt-3 w-full">Get early access<Icon name="arrow-right" class="h-4 w-4" /></Button>
          <p class="text-center text-xs text-muted-foreground">Prefer a walkthrough? <a href="#early-access" class="font-medium text-primary underline-offset-4 hover:underline">Request a demo</a>.</p>
        </form>
      </div>
    </div>
  </div>
</section>
