---
import BrandLockup from "./BrandLockup.astro";
import Button from "./ui/Button.astro";
import Icon from "./Icon.astro";
import { primaryNav } from "../lib/nav";

const path = Astro.url.pathname;
const isActive = (href: string) => path === href || (href !== "/" && path.startsWith(href));
---
<header class="sticky top-0 z-50 border-b border-border/50 bg-card/70 backdrop-blur-md">
  <div class="mx-auto flex h-16 max-w-7xl items-center justify-between gap-2 px-4 sm:px-6 lg:px-8">
    <a href="/" class="flex min-w-0 items-center" aria-label="EffortlessAuthor home">
      <BrandLockup size="sm" compact />
    </a>

    <nav class="hidden items-center gap-8 lg:flex" aria-label="Primary">
      {primaryNav.map((l) => (
        <a
          href={l.href}
          class:list={["text-[15px] font-medium transition-colors hover:text-foreground", isActive(l.href) ? "text-foreground" : "text-muted-foreground"]}
        >{l.label}</a>
      ))}
    </nav>

    <div class="flex items-center gap-2 sm:gap-3">
      <button
        type="button"
        id="theme-toggle"
        class="flex h-9 w-9 items-center justify-center rounded-md border border-input bg-background text-foreground transition-colors hover:bg-accent"
        aria-label="Toggle dark mode"
      >
        <Icon name="sun" class="hidden h-4 w-4 dark:block" />
        <Icon name="moon" class="h-4 w-4 dark:hidden" />
      </button>
      <Button href="/early-access" variant="ghost" size="sm" class="hidden lg:inline-flex">Sign in</Button>
      <Button href="/early-access" variant="gradient" size="sm">Early access<Icon name="arrow-right" class="h-4 w-4" /></Button>
      <button
        type="button"
        id="nav-toggle"
        class="flex h-9 w-9 items-center justify-center rounded-md border border-input bg-background text-foreground transition-colors hover:bg-accent lg:hidden"
        aria-label="Open menu"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <Icon name="menu" class="h-5 w-5" data-icon="menu" />
        <Icon name="x" class="hidden h-5 w-5" data-icon="close" />
      </button>
    </div>
  </div>

  <!-- mobile menu -->
  <div id="mobile-menu" class="hidden border-t border-border/50 bg-card/95 backdrop-blur-md lg:hidden">
    <nav class="mx-auto flex max-w-7xl flex-col gap-1 px-6 py-4" aria-label="Mobile">
      {primaryNav.map((l) => (
        <a
          href={l.href}
          class:list={["rounded-md px-3 py-2.5 text-[15px] font-medium transition-colors hover:bg-accent", isActive(l.href) ? "bg-accent text-foreground" : "text-muted-foreground"]}
        >{l.label}</a>
      ))}
      <Button href="/early-access" variant="outline" size="default" class="mt-2 w-full justify-center">Sign in</Button>
    </nav>
  </div>
</header>

<script>
  // Dark-mode toggle (no-flash init lives in Base.astro <head>).
  const themeToggle = document.getElementById("theme-toggle");
  themeToggle?.addEventListener("click", () => {
    const isDark = document.documentElement.classList.toggle("dark");
    try { localStorage.setItem("theme", isDark ? "dark" : "light"); } catch (_) {}
  });

  const toggle = document.getElementById("nav-toggle");
  const menu = document.getElementById("mobile-menu");
  if (toggle && menu) {
    const menuIcon = toggle.querySelector('[data-icon="menu"]');
    const closeIcon = toggle.querySelector('[data-icon="close"]');
    toggle.addEventListener("click", () => {
      const open = menu.classList.toggle("hidden") === false;
      toggle.setAttribute("aria-expanded", String(open));
      toggle.setAttribute("aria-label", open ? "Close menu" : "Open menu");
      menuIcon?.classList.toggle("hidden", open);
      closeIcon?.classList.toggle("hidden", !open);
    });
  }
</script>
