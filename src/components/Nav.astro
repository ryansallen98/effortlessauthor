---
import BrandLockup from "./BrandLockup.astro";
import Button from "./ui/Button.astro";
import Icon from "./Icon.astro";

const links = [
  { href: "#workflow", label: "Workflow" },
  { href: "#product", label: "Product" },
  { href: "#kdp", label: "KDP pipeline" },
  { href: "#audio", label: "Audio" },
  { href: "#use-cases", label: "Use cases" },
];
---
<header class="sticky top-0 z-50 border-b border-border/50 bg-card/70 backdrop-blur-md">
  <div class="mx-auto flex h-16 max-w-7xl items-center justify-between px-6 lg:px-8">
    <a href="#top" class="flex items-center" aria-label="EffortlessAuthor home">
      <BrandLockup size="sm" />
    </a>
    <nav class="hidden items-center gap-8 md:flex">
      {links.map((l) => (
        <a href={l.href} class="text-[15px] font-medium text-muted-foreground transition-colors hover:text-foreground">{l.label}</a>
      ))}
    </nav>
    <div class="flex items-center gap-3">
      <Button href="#early-access" variant="ghost" size="sm" class="hidden sm:inline-flex">Sign in</Button>
      <Button href="#early-access" variant="gradient" size="sm">Early access<Icon name="arrow-right" class="h-4 w-4" /></Button>
    </div>
  </div>
</header>
