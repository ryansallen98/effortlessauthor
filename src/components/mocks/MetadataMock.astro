---
/**
 * Recreation of the KDP metadata editor (app/src/components/editor/KDPMetadataEditor.tsx):
 * Basic / Description / Series / Discovery / Specs tabs, with the Discovery tab
 * shown (keywords + categories) and a "Copy for KDP" control.
 */
import Icon from "../Icon.astro";
import Button from "../ui/Button.astro";
import Badge from "../ui/Badge.astro";
import Label from "../ui/Label.astro";
import TabsList from "../ui/TabsList.astro";
import TabsTrigger from "../ui/TabsTrigger.astro";

const keywords = ["enochian magic", "ceremonial ritual", "angelic invocation", "western esotericism", "grimoire"];
---
<div class="@container overflow-hidden rounded-lg border bg-card shadow-soft-lg" role="img" aria-label="KDP metadata editor showing the Discovery tab with keywords and categories">
  <div class="flex h-9 items-center gap-2.5 border-b border-border/70 bg-muted/50 px-3.5">
    <span class="flex gap-1.5">
      <span class="h-2.5 w-2.5 rounded-full bg-destructive/45"></span>
      <span class="h-2.5 w-2.5 rounded-full bg-amber-500/55"></span>
      <span class="h-2.5 w-2.5 rounded-full bg-emerald-500/50"></span>
    </span>
    <span class="flex-1 truncate text-center font-mono text-[11px] text-muted-foreground">KDP Publishing Settings</span>
  </div>

  <div class="p-4">
    <TabsList class="flex h-auto w-full flex-wrap justify-start gap-1">
      <TabsTrigger class="flex-1 gap-1.5"><Icon name="book-open" class="h-3.5 w-3.5" />Basic</TabsTrigger>
      <TabsTrigger class="flex-1 gap-1.5"><Icon name="file-text" class="h-3.5 w-3.5" />Description</TabsTrigger>
      <TabsTrigger class="flex-1 gap-1.5"><Icon name="list-ordered" class="h-3.5 w-3.5" />Series</TabsTrigger>
      <TabsTrigger active class="flex-1 gap-1.5"><Icon name="tag" class="h-3.5 w-3.5" />Discovery</TabsTrigger>
      <TabsTrigger class="flex-1 gap-1.5"><Icon name="package" class="h-3.5 w-3.5" />Specs</TabsTrigger>
    </TabsList>

    <div class="mt-4 grid gap-4">
      <div class="flex flex-col gap-1.5">
        <Label class="flex items-center gap-2">Keywords <span class="text-xs font-normal text-muted-foreground">(5 / 7)</span></Label>
        <div class="flex flex-wrap gap-1.5">
          {keywords.map((k) => (
            <Badge variant="primary">{k}<Icon name="plus" class="h-2.5 w-2.5 rotate-45" /></Badge>
          ))}
        </div>
        <span class="text-[11px] text-muted-foreground">Up to 7 keywords · 50 characters each</span>
      </div>

      <div class="flex flex-col gap-1.5">
        <Label class="flex items-center gap-2">Categories <span class="text-xs font-normal text-muted-foreground">(2 / 3)</span></Label>
        <div class="flex h-9 items-center gap-2 rounded-md border border-border/60 bg-muted/40 px-2.5 text-[13px]"><Icon name="list-ordered" class="h-3.5 w-3.5 text-muted-foreground" />Religion &amp; Spirituality › Occultism</div>
        <div class="flex h-9 items-center gap-2 rounded-md border border-border/60 bg-muted/40 px-2.5 text-[13px]"><Icon name="list-ordered" class="h-3.5 w-3.5 text-muted-foreground" />Body, Mind &amp; Spirit › Magic Studies</div>
      </div>

      <div class="flex flex-col gap-1.5">
        <Label class="flex items-center gap-2">Book description <span class="text-xs font-normal text-muted-foreground">(1,842 / 4,000)</span></Label>
        <div class="rounded-md border border-input bg-background/50 p-3">
          <div class="flex flex-col gap-2">
            <span class="h-2 w-[92%] rounded-full bg-muted-foreground/15"></span>
            <span class="h-2 w-[80%] rounded-full bg-muted-foreground/15"></span>
            <span class="h-2 w-[88%] rounded-full bg-muted-foreground/15"></span>
            <span class="h-2 w-[50%] rounded-full bg-muted-foreground/15"></span>
          </div>
          <div class="mt-3 flex items-center justify-between gap-3">
            <span class="text-[11px] text-muted-foreground">KDP-safe HTML · allowed tags only</span>
            <span class="inline-flex items-center gap-1.5 rounded-full bg-primary/10 px-2 py-1 text-[11px] font-semibold text-primary"><Icon name="copy" class="h-3 w-3" />Copy for KDP</span>
          </div>
        </div>
      </div>
    </div>

    <div class="mt-4 flex flex-wrap items-center justify-between gap-3 border-t border-border/50 pt-4">
      <span class="inline-flex items-center gap-2 text-xs text-muted-foreground"><Icon name="check" class="h-3.5 w-3.5 text-emerald-600" />Title, language, and author present</span>
      <Button variant="gradient" size="sm"><Icon name="save" class="h-4 w-4" />Save All Changes</Button>
    </div>
  </div>
</div>
