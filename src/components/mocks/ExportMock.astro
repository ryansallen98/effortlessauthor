---
/**
 * Recreation of the export/validation surface (app/src/app/api/books/[slug]/export/validate).
 * A KDP-aware validation report: each artifact the EPUB pipeline prepares,
 * with pass/review states. Wording stays "KDP-aware", never "guaranteed".
 */
import Icon from "../Icon.astro";
import Button from "../ui/Button.astro";
import Badge from "../ui/Badge.astro";

const checks = [
  { label: "Strict XHTML content documents", state: "ok" },
  { label: "KDP-safe CSS (inlined, scoped)", state: "ok" },
  { label: "OPF package + manifest", state: "ok" },
  { label: "nav.xhtml navigation document", state: "ok" },
  { label: "Legacy toc.ncx fallback", state: "ok" },
  { label: "Cover image embedded", state: "ok" },
  { label: "Metadata: title, language, author", state: "ok" },
  { label: "Description within 4,000 chars", state: "warn", note: "3,980 / 4,000" },
];
---
<div class="@container overflow-hidden rounded-lg border bg-card shadow-soft-lg" role="img" aria-label="KDP-aware export validation report">
  <div class="flex items-center justify-between gap-3 border-b border-border/50 bg-card/60 px-4 py-3 backdrop-blur-md">
    <span class="flex items-center gap-2">
      <span class="flex h-8 w-8 items-center justify-center rounded-md bg-gradient-to-br from-primary/20 to-orange-500/20 text-primary"><Icon name="shield-check" class="h-4 w-4" /></span>
      <span class="font-serif text-sm font-bold leading-tight">Export validation
        <span class="block text-[11px] font-sans font-normal text-muted-foreground">the-enochian-keys.epub</span>
      </span>
    </span>
    <Badge variant="emerald"><span class="h-2 w-2 rounded-full bg-emerald-500"></span>7 / 8 passed</Badge>
  </div>

  <div class="flex flex-col gap-2 p-4">
    {checks.map((c) => (
      <div class="flex items-center gap-2.5 rounded-md border border-border/60 bg-card/75 px-3 py-2.5 text-[13px]">
        {c.state === "ok" ? (
          <span class="text-emerald-600"><Icon name="check" class="h-4 w-4" /></span>
        ) : (
          <span class="text-amber-600"><Icon name="alert-triangle" class="h-4 w-4" /></span>
        )}
        <span class="flex-1">{c.label}</span>
        {c.note && <Badge variant="amber">{c.note}</Badge>}
      </div>
    ))}
  </div>

  <div class="flex items-center justify-between gap-3 border-t border-border/50 px-4 py-3">
    <span class="text-[11px] text-muted-foreground">KDP-aware checks · review warnings before upload</span>
    <Button variant="gradient" size="sm"><Icon name="file-down" class="h-4 w-4" />Export EPUB</Button>
  </div>
</div>
