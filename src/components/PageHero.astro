---
import Icon from "./Icon.astro";
import Badge from "./ui/Badge.astro";
interface Props { eyebrow?: string; eyebrowIcon?: string; title: string; lead?: string; }
const { eyebrow, eyebrowIcon = "sparkles", title, lead } = Astro.props;
---
<section class="relative overflow-hidden border-b border-border/50">
  <div class="pointer-events-none absolute inset-0 overflow-hidden" aria-hidden="true">
    <div class="absolute -right-32 -top-32 h-80 w-80 rounded-full bg-primary/5 blur-3xl"></div>
    <div class="absolute -left-20 top-1/2 h-64 w-64 rounded-full bg-amber-500/5 blur-3xl"></div>
  </div>
  <div class="relative mx-auto max-w-3xl px-6 py-16 text-center lg:px-8 lg:py-20">
    {eyebrow && (
      <Badge variant="primary" class="mb-5"><Icon name={eyebrowIcon} class="h-3.5 w-3.5" />{eyebrow}</Badge>
    )}
    <h1 class="font-serif text-4xl font-bold tracking-tight sm:text-5xl">{title}</h1>
    {lead && <p class="mx-auto mt-5 max-w-2xl text-lg text-muted-foreground">{lead}</p>}
    <slot />
  </div>
</section>
