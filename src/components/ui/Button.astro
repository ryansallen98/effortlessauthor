---
/**
 * Astro mirror of app/src/components/ui/button.tsx (shadcn).
 * Same base classes, variants, and sizes. Renders <a> when `href` is set,
 * otherwise <button>. `variant="gradient"` is the app's primary-CTA override
 * (bg-gradient-to-r from-primary to-orange-600 shadow-soft).
 */
import { cn } from "@/lib/utils";

type Variant =
  | "default"
  | "destructive"
  | "outline"
  | "secondary"
  | "ghost"
  | "link"
  | "gradient";
type Size = "default" | "sm" | "lg" | "icon";

interface Props {
  variant?: Variant;
  size?: Size;
  href?: string;
  type?: "button" | "submit" | "reset";
  class?: string;
  [key: string]: unknown;
}

const base =
  "inline-flex items-center justify-center whitespace-nowrap rounded-md text-sm font-medium ring-offset-background transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 disabled:pointer-events-none disabled:opacity-50";

const variants: Record<Variant, string> = {
  default: "bg-primary text-primary-foreground hover:bg-primary/90",
  destructive:
    "bg-destructive text-destructive-foreground hover:bg-destructive/90",
  outline:
    "border border-input bg-background hover:bg-accent hover:text-accent-foreground",
  secondary: "bg-secondary text-secondary-foreground hover:bg-secondary/80",
  ghost: "hover:bg-accent hover:text-accent-foreground",
  link: "text-primary underline-offset-4 hover:underline",
  gradient:
    "bg-gradient-to-r from-primary to-orange-600 text-primary-foreground hover:from-primary/90 hover:to-orange-600/90 shadow-soft",
};

const sizes: Record<Size, string> = {
  default: "h-10 px-4 py-2",
  sm: "h-9 rounded-md px-3",
  lg: "h-11 rounded-md px-8",
  icon: "h-10 w-10",
};

const {
  variant = "default",
  size = "default",
  href,
  type = "button",
  class: className,
  ...rest
} = Astro.props;

const classes = cn(base, variants[variant], sizes[size], className);
const Tag = href ? "a" : "button";
---
<Tag class={classes} href={href} type={href ? undefined : type} {...rest}>
  <slot />
</Tag>
