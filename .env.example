# Copy to `.env` and fill in. `.env` is gitignored; this example is committed.

# Public base URL — drives canonical tags, sitemap, RSS, and OG image URLs.
# Required for any real build/deploy. Dev falls back to http://localhost:4321
# if unset. No trailing slash. Set this once the launch domain is chosen.
SITE_URL=https://your-domain.com

# Optional: enables the privacy-friendly Plausible analytics script for this
# domain. Leave unset to ship no analytics.
# PUBLIC_PLAUSIBLE_DOMAIN=your-domain.com
